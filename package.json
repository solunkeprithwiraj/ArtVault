{
  "name": "artvault",
  "version": "0.1.0",
  "private": true,
  "description": "Personal art gallery - curate and display art, videos, and images",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @artvault/web dev",
    "dev:api": "pnpm --filter @artvault/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20"
  }
}
