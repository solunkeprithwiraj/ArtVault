# Database (local: postgresql://postgres:postgres@localhost:5432/artvault)
# Production: use Neon connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/artvault?schema=public"

# Server
PORT=4001

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3001

# Auth (JWT)
JWT_SECRET="change-this-to-a-random-secret"

# Superadmin credentials (used by seed script)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
