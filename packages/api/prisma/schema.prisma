datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  SUPERADMIN
  USER
}

enum MediaType {
  IMAGE
  VIDEO
  IFRAME
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  role         Role         @default(USER)
  artPieces    ArtPiece[]
  collections  Collection[]
  notes        Note[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("users")
}

model ArtPiece {
  id           String      @id @default(cuid())
  title        String
  description  String?
  mediaType    MediaType
  sourceUrl    String
  thumbnailUrl String?
  tags         String[]
  sortOrder    Int         @default(0)
  isFavorite   Boolean     @default(false)
  isPinned     Boolean     @default(false)
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  notes        Note[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([collectionId])
  @@index([userId, createdAt])
  @@index([userId, isFavorite])
  @@index([userId, mediaType])
  @@map("art_pieces")
}

model Collection {
  id          String       @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  parentId    String?
  parent      Collection?  @relation("CollectionTree", fields: [parentId], references: [id])
  children    Collection[] @relation("CollectionTree")
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  artPieces   ArtPiece[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, userId])
  @@index([userId])
  @@index([parentId])
  @@map("collections")
}

model Note {
  id         String   @id @default(cuid())
  content    String
  artPiece   ArtPiece @relation(fields: [artPieceId], references: [id], onDelete: Cascade)
  artPieceId String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([artPieceId])
  @@index([userId])
  @@map("notes")
}
