datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum MediaType {
  IMAGE
  VIDEO
  IFRAME
}

model ArtPiece {
  id           String      @id @default(cuid())
  title        String
  description  String?
  mediaType    MediaType
  sourceUrl    String
  thumbnailUrl String?
  tags         String[]
  sortOrder    Int         @default(0)
  isFavorite   Boolean     @default(false)
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  notes        Note[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("art_pieces")
}

model Collection {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  coverUrl    String?
  parentId    String?
  parent      Collection?  @relation("CollectionTree", fields: [parentId], references: [id])
  children    Collection[] @relation("CollectionTree")
  artPieces   ArtPiece[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("collections")
}

model Note {
  id         String   @id @default(cuid())
  content    String
  artPiece   ArtPiece @relation(fields: [artPieceId], references: [id], onDelete: Cascade)
  artPieceId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notes")
}
