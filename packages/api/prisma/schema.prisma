datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum MediaType {
  IMAGE
  VIDEO
  IFRAME
}

model ArtPiece {
  id           String      @id @default(cuid())
  title        String
  description  String?
  mediaType    MediaType
  sourceUrl    String
  thumbnailUrl String?
  tags         String[]
  sortOrder    Int         @default(0)
  isFavorite   Boolean     @default(false)
  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("art_pieces")
}

model Collection {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  coverUrl    String?
  artPieces   ArtPiece[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("collections")
}
